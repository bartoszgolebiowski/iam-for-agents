# Keycloak Configuration
# URL to your Keycloak instance (running in docker-compose network)
KEYCLOAK_URL=http://keycloak:8080

# Keycloak realm name (default: master)
KEYCLOAK_REALM=master

# Orchestrator App Client Credentials (from Keycloak clients.yaml)
ORCHESTRATOR_CLIENT_ID=orchestrator-app
ORCHESTRATOR_CLIENT_SECRET=orchestrator-secret

# Audiences for token exchange
NOTES_AUDIENCE=notes-app
TODO_AUDIENCE=todo-app

# API URLs (can be customized if apps run on different hosts)
NOTES_API_URL=http://notes-app:3002
TODO_API_URL=http://todo-app:3001

# UI Configuration
UI_TITLE=Orchestrator
